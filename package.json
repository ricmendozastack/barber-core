{
  "name": "barber-core",
  "version": "1.0.0",
  "main": "src/bootstrap/index.ts",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.12.0",
  "scripts": {
    "start": "cross-env APP_ENV=development expo start",
    "start:qa": "cross-env APP_ENV=qa expo start",
    "start:staging": "cross-env APP_ENV=staging expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "expo": "~57.0.4",
    "expo-constants": "~57.0.3",
    "expo-status-bar": "~57.0.0",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/react": "~19.2.2",
    "babel-plugin-module-resolver": "^5.0.3",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.5",
    "eslint-config-expo": "~57.0.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "typescript": "~6.0.3"
  }
}
