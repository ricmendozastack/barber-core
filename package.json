{
  "name": "barber-core",
  "version": "1.0.0",
  "main": "src/bootstrap/index.ts",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.12.0",
  "scripts": {
    "start": "cross-env APP_ENV=development expo start",
    "start:qa": "cross-env APP_ENV=qa expo start",
    "start:staging": "cross-env APP_ENV=staging expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^7.18.8",
    "@react-navigation/native": "^7.3.8",
    "@react-navigation/native-stack": "^7.17.10",
    "@tanstack/react-query": "^5.101.2",
    "axios": "^1.18.1",
    "expo": "~57.0.4",
    "expo-constants": "~57.0.3",
    "expo-secure-store": "~57.0.0",
    "expo-status-bar": "~57.0.0",
    "nativewind": "^4.2.6",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-css-interop": "^0.2.6",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-mmkv": "^4.3.2",
    "react-native-nitro-modules": "^0.36.1",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-worklets": "0.10.0",
    "tailwindcss": "^3.4.19",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/react": "~19.2.2",
    "babel-plugin-module-resolver": "^5.0.3",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.5",
    "eslint-config-expo": "~57.0.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "typescript": "~6.0.3"
  }
}
